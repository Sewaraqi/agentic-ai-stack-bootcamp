# Copy this file to .env and fill in your keys
# Never commit the real .env file

# Required for all modules
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-1.5-flash
GEMINI_TEMPERATURE=0.0

# Required for modules 02+ (embeddings)
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Required for modules 03-04 and cv-hiring-agent (Pinecone RAG)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_index_name_here
PINECONE_NAMESPACE=your_namespace_here

# Optional overrides (modules 01, assignments)
MEMORY_FILE=data/memory_store.json
MAX_RECALLED_SESSIONS=3

# Optional overrides (assignment 05 - sliding window)
MAX_HISTORY_TURNS=4

# Optional overrides (assignment 06 - token-aware chatbot)
TOKEN_LIMIT=32000
SUMMARY_THRESHOLD=0.75
MIN_RESPONSE_TOKENS=500
